{
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/accounts/(.+)", "dest": "/api/accounts/[id].js?id=$1" },
    { "src": "/api/accounts", "dest": "/api/accounts.js" },
    { "src": "/api/upload-qr", "dest": "/api/upload-qr.js" },
    { "src": "/api/banks", "dest": "/api/banks.js" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/app.js", "dest": "/public/app.js" },
    { "src": "/manifest.json", "dest": "/public/manifest.json" },
    { "src": "/sw.js", "dest": "/public/sw.js" },
    { "src": "/icon-192.png", "dest": "/public/icon-192.png" },
    { "src": "/icon-512.png", "dest": "/public/icon-512.png" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
